{
  "expo": {
    "name": "蒐集架",
    "slug": "booknest",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "booknest",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.booknest.app",
      "infoPlist": {
        "NSCameraUsageDescription": "ISBN barcode scanning is used to register books.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.booknest.app",
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "ISBN barcode scanning is used to register books.",
          "microphonePermission": false,
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-notifications",
        {
          "defaultChannel": "new-releases"
        }
      ],
      [
        "expo-alternate-app-icons",
        [
          {
            "name": "Green",
            "ios": "./assets/ios-alternate-icons/green.png",
            "android": {
              "foregroundImage": "./assets/ios-alternate-icons/green.png",
              "backgroundColor": "#e8f2e8"
            }
          },
          {
            "name": "Gold",
            "ios": "./assets/ios-alternate-icons/gold.png",
            "android": {
              "foregroundImage": "./assets/ios-alternate-icons/gold.png",
              "backgroundColor": "#fff6df"
            }
          },
          {
            "name": "Rose",
            "ios": "./assets/ios-alternate-icons/rose.png",
            "android": {
              "foregroundImage": "./assets/ios-alternate-icons/rose.png",
              "backgroundColor": "#fde9ec"
            }
          },
          {
            "name": "Brown",
            "ios": "./assets/ios-alternate-icons/brown.png",
            "android": {
              "foregroundImage": "./assets/ios-alternate-icons/brown.png",
              "backgroundColor": "#f5eadc"
            }
          },
          {
            "name": "Teal",
            "ios": "./assets/ios-alternate-icons/teal.png",
            "android": {
              "foregroundImage": "./assets/ios-alternate-icons/teal.png",
              "backgroundColor": "#e8f7f8"
            }
          },
          {
            "name": "Purple",
            "ios": "./assets/ios-alternate-icons/purple.png",
            "android": {
              "foregroundImage": "./assets/ios-alternate-icons/purple.png",
              "backgroundColor": "#efe2ff"
            }
          },
          {
            "name": "Gray",
            "ios": "./assets/ios-alternate-icons/gray.png",
            "android": {
              "foregroundImage": "./assets/ios-alternate-icons/gray.png",
              "backgroundColor": "#f1f3f6"
            }
          },
          {
            "name": "Yellow",
            "ios": "./assets/ios-alternate-icons/yellow.png",
            "android": {
              "foregroundImage": "./assets/ios-alternate-icons/yellow.png",
              "backgroundColor": "#fff3a4"
            }
          }
        ]
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "f9d01088-83a6-467c-b384-76e03bc3bc6d"
      },
      "router": {}
    }
  }
}
